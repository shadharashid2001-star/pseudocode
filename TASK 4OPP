      ADD_SALE(ADDSALE:SALE)
	   SET CHECKTSTOCK TO TRUE
		 IF STOCK IS LESS THEN ADDSALE.QUANTITY THEN
		   DISPLAY "STOCK IS LESS THAN REQUIRED"
		    SET CHECKTSTOCK TO FALSE
		  END IF
	     IF CHECKTSTOCK IS EQUAL TRUE THEN
		   ADD ADDSALE TO SALE
		   SET STOCK TO STOCK - ADDSALE.QUANTITY
		 END IF
		 END METHOD
		
		
