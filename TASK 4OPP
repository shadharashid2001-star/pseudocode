   CLASS BOOKSHOP
     ATTRIBUTES
      PRIVATE ID : NUMBER
	  PRIVATE NAME : TEXT
	  PRIVATE EMAIL: TEXT
	  PRIVATE PHONE: TEXT
	  PRIVATE CUSTOMER : LIST<CUSTOMER>
	  PRIVATE BOOK : LIST<BOOK>

	 CONSTRUCTOR(N:TEXT,EM:TEXT,PHO:TEXT,C:LIST<CUSTOMER>,B:LIST<BOOK>)
	    SET NAME TO N
		SET EMAIL TO EM
	    SET PHONE TO PHO
		SET CUSTOMER TO C
        SET BOOK TO B		
	   END CONSTRUCTOR
	
	  METHODS
	
	   GET_NAME()
	    DISPLAY NAME
	   END METHOD

	   GET_EMAIL()
	    DISPLAY EMAIL
	   END METHOD
	
	   GET_PHONE()
	    DISPLAY PHONE
	   END METHOD
	
	   ADD_CUSTOMER(ADDCUSTOMER:CUSTOMER)
	   SET CHECK TO TRUE
	     IF LENGTH OF ADDCUSTOMER.NAME IS LESS THAN 3 THEN
		   DISPLAY "ENTER VALID NAME"
		    RETURN
		 END IF
		
		REPEAT FROM I = 1 TO SIZE OF CUSTOMER
		   IF CUSTOMER[I].PHONE EQUAL ADDCUSTOMER.PHONE THEN
		     DISPLAY "CUSTOMER ALREADY REGISTERED"
			   SET CHECK TO FALSE				
		   END IF
		END REPEAT
		
		  IF CHECK EQUAL TRUE THEN
           ADD ADDCUSTOMER TO CUSTOMER
		  ELSE
		    DISPLAY "ERROR"
		END METHOD
		 	
		
		ADD_BOOK(ADDBOOK:BOOK)
		 SET CHECKBOOK TO TRUE
		 REPEAT FROM I = 1 TO SIZE OF BOOK
		  IF BOOK[I].TITLE  IS EQUAL ADDBOOK.TITLE  AND BOOK[I].AUTHOR IS EQUAL ADDBOOK.AUTHOR
		    DISPLAY "BOOK IS ALERDY ENTERD"
			  SET CHECKBOOK TO FALSE
	      END IF
		END METHOD
		
			  IF CHECK EQUAL TRUE THEN
           ADD ADDBOOK TO BOOK
		  ELSE
		    DISPLAY "ERROR"
		  END IF
		END METHOD

       GET_CUSTOMER()
	     DISPLAY CUSTOMER
	   END METHOD
	
       GET_BOOK()
	     DISPLAY BOOK
	   END METHOD

	
	END CLASS

