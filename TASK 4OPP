CLASS EXAM
   ATTRIBUTES
      PRIVATE ID : NUMBER
      PRIVATE TITLE : TEXT
      PRIVATE TIMELIMIT : NUMBER
      PRIVATE QUESTION : LIST<QUESTION>

   CONSTRUCTOR(T:TEXT, TI:NUMBER, Q:LIST<QUESTION>)
      SET TITLE TO T
      SET TIMELIMIT TO TI
      SET Q TO QUESTION
   END CONSTRUCTOR
   
  METHODS
    ADD_QUESTION(ADDQUESTION:QUESTION)
    SET CHECK TO TRUE
    IF LENGTH OF ADDQUESTION.QUESTIONTEXT IS LESS THAN 1 THEN
        DISPLAY "INVALID QUESTION"
        SET CHECK TO FALSE
    END IF
    IF ADDQUESTION.POINT GREATER THAN 0 THEN
        DISPLAY "INVALID POINT"
        SET CHECK TO FALSE
    END IF
    IF CHECK EQUAL TRUE THEN
        ADD ADDQUESTION TO QUESTION
    END IF

  END METHOD

     GET_TITLE()
      DISPLAY TITLE
	  END METHOD
	  GET_QUESTION()
      DISPLAY QUESTION
   END METHOD

 END CLASS

 CLASS QUESTION
   ATTRIBUTES
      PRIVATE ID : NUMBER
      PRIVATE QUESTIONTEXT : TEXT
      PRIVATE CORRECTANSWER : TEXT
      PRIVATE POINT : NUMBER

   CONSTRUCTOR(QT:TEXT, CA:TEXT, P:NUMBER)
      SET QUESTIONTEXT TO QT
      SET CORRECTANSWER TO CA
      SET POINT TO P
   END CONSTRUCTOR

   METHODS

   GET_QUESTION()
      DISPLAY QUESTIONTEXT
   END METHOD

   GET_CORRECTANSWER()
      DISPLAY CORRECTANSWER
   END METHOD

   GET_POINT()
