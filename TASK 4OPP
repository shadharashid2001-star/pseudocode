 CLASS ROOM
   ATTRIBUTES
    PRIVATE ID : NUMBER
    PRIVATE ROOMNAME : TEXT
    PRIVATE BOOKING : LIST<BOOKING>

  CONSTRUCTOR(I:NUMBER,R:TEXT,B:LIST<BOOKING>)
    SET ID TO I
    SET ROOMNAME TO R
    SET BOOKING TO B
   END CONSTRUCTOR
  METHODS

  ADD_BOOKING(ADDBOOKING:BOOKING)

    SET CHECK TO TRUE
    REPEAT FROM I = 1 TO SIZE OF BOOKING
        IF ADDBOOKING.STARTTIME IS LESS THAN BOOKING[I].ENDTIME AND
           ADDBOOKING.ENDTIME GREATER THAN BOOKING[I].STARTTIME THEN
            DISPLAY "ROOM ALREADY BOOKED"
            SET CHECK TO FALSE
        END IF

    END REPEAT
    IF CHECK EQUAL TRUE THEN
        ADD ADDBOOKING TO BOOKING
    END IF
   END METHOD

  END CLASS

