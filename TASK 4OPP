CLASS BOOKSHOP

ATTRIBUTES
PRIVATE ID : NUMBER
PRIVATE NAME : TEXT
PRIVATE EMAIL : TEXT
PRIVATE PHONE : TEXT
PRIVATE CUSTOMER : LIST<CUSTOMER>
PRIVATE BOOK : LIST<BOOK>

CONSTRUCTOR(N:TEXT,EM:TEXT,PHO:TEXT)
    SET NAME TO N
    SET EMAIL TO EM
    SET PHONE TO PHO
    SET CUSTOMER TO EMPTY LIST
    SET BOOK TO EMPTY LIST
END CONSTRUCTOR

METHODS

GET_NAME()
    DISPLAY NAME
END METHOD

GET_EMAIL()
    DISPLAY EMAIL
END METHOD

GET_PHONE()
    DISPLAY PHONE
END METHOD

ADD_CUSTOMER(ADDCUSTOMER:CUSTOMER)
    SET CHECK TO TRUE

    IF LENGTH OF ADDCUSTOMER.NAME IS LESS THAN 3 THEN
        DISPLAY "ENTER VALID NAME"
        SET CHECK TO FALSE
    END IF

    REPEAT FROM I = 1 TO SIZE OF CUSTOMER
        IF CUSTOMER[I].PHONE EQUALS ADDCUSTOMER.PHONE THEN
            DISPLAY "CUSTOMER ALREADY REGISTERED"
            SET CHECK TO FALSE
        END IF
    END REPEAT

    IF CHECK EQUALS TRUE THEN
        ADD ADDCUSTOMER TO CUSTOMER
    ELSE
        DISPLAY "ERROR"
    END IF
END METHOD

ADD_BOOK(ADDBOOK:BOOK)
    SET CHECKBOOK TO TRUE

    REPEAT FROM I = 1 TO SIZE OF BOOK
        IF BOOK[I].TITLE EQUALS ADDBOOK.TITLE AND BOOK[I].AUTHOR EQUALS ADDBOOK.AUTHOR THEN
            DISPLAY "BOOK ALREADY EXISTS"
            SET CHECKBOOK TO FALSE
        END IF
    END REPEAT

    IF CHECKBOOK EQUALS TRUE THEN
        ADD ADDBOOK TO BOOK
    ELSE
        DISPLAY "ERROR"
    END IF
END METHOD

GET_CUSTOMER()
    DISPLAY CUSTOMER
END METHOD

GET_BOOK()
    DISPLAY BOOK
END METHOD

END CLASS


CLASS BOOK

ATTRIBUTES
PRIVATE ID : NUMBER
PRIVATE TITLE : TEXT
PRIVATE AUTHOR : TEXT
PRIVATE PRICE : NUMBER
PRIVATE GENRE : TEXT
PRIVATE STOCK : NUMBER
PRIVATE SALE : LIST<SALE>

CONSTRUCTOR(TI:TEXT,AU:TEXT,ST:NUMBER,PR:NUMBER,GE:TEXT)
    SET TITLE TO TI
    SET AUTHOR TO AU
    SET STOCK TO ST
    SET PRICE TO PR
    SET GENRE TO GE
    SET SALE TO EMPTY LIST
END CONSTRUCTOR

METHODS

GET_TITLE()
    DISPLAY TITLE
END METHOD

SET_TITLE(NEWTITLE:TEXT)
    IF LENGTH OF NEWTITLE GREATER THAN OR EQUAL TO 3 THEN
        SET TITLE TO NEWTITLE
    ELSE
        DISPLAY "TITLE MUST CONTAIN AT LEAST 3 CHARACTERS"
    END IF
END METHOD

GET_AUTHOR()
    DISPLAY AUTHOR
END METHOD

GET_PRICE()
    DISPLAY PRICE
END METHOD

GET_GENRE()
    DISPLAY GENRE
END METHOD

ADD_SALE(ADDSALE:SALE)

    IF STOCK LESS THAN ADDSALE.QUANTITY THEN
        DISPLAY "STOCK IS LESS THAN REQUIRED"
    ELSE
        ADD ADDSALE TO SALE
        SET STOCK TO STOCK - ADDSALE.QUANTITY
    END IF

END METHOD

END CLASS


