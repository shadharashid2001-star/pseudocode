CLASS MEMBER

ATTRIBUTES
    PRIVATE ID : NUMBER
    PRIVATE NAME : TEXT
    PRIVATE PHONE : TEXT
    PRIVATE MEMBERSHIP : MEMBERSHIP
    PRIVATE BOOKING : LIST<BOOKING>

CONSTRUCTOR(I:NUMBER,N:TEXT,PH:TEXT,MP:MEMBERSHIP)
    SET ID TO I
    SET NAME TO N
    SET PHONE TO PH
    SET MEMBERSHIP TO MP
    SET BOOKING TO EMPTY LIST
END CONSTRUCTOR

METHODS

GET_NAME()
    DISPLAY NAME
END METHOD

GET_PHONE()
    DISPLAY PHONE
END METHOD

ADD_BOOKING(ADDBOOKING:BOOKING)

    SET USED_HOURS TO 0

    REPEAT FROM I = 1 TO SIZE OF BOOKING
        SET USED_HOURS TO USED_HOURS + BOOKING[I].HOURS
    END REPEAT

    IF USED_HOURS + ADDBOOKING.HOURS GREATER THAN MEMBERSHIP.MONTHLYQUOTA THEN
        DISPLAY "MONTHLY QUOTA EXCEEDED"
    ELSE
        ADD ADDBOOKING TO BOOKING
    END IF

END METHOD

GET_REMAINING_HOURS()

    SET USED_HOURS TO 0

    REPEAT FROM I = 1 TO SIZE OF BOOKING
        SET USED_HOURS TO USED_HOURS + BOOKING[I].HOURS
    END REPEAT

    DISPLAY MEMBERSHIP.MONTHLYQUOTA - USED_HOURS

END METHOD

END CLASS


