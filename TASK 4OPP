 END CLASS
 CLASS ATTEMPT
   ATTRIBUTES
      PRIVATE ID : NUMBER
      PRIVATE EXAM : EXAM
      PRIVATE SELECTEDANSWER : LIST<TEXT>
      PRIVATE SCORE : NUMBER
      PRIVATE TIMEUP : BOOLEAN

   CONSTRUCTOR(E:EXAM)
      SET EXAM TO E
      SET SCORE TO 0
      SET TIMEUP TO FALSE
   END CONSTRUCTOR
   METHODS

   ADD_ANSWER(A:TEXT)
      IF TIMEUP EQUAL TRUE THEN
         DISPLAY "TIME IS OVER"
      ELSE
         ADD A TO SELECTEDANSWER
      END IF
   END METHOD
   
   CALCULATE_SCORE()
      SET SCORE TO 0
      REPEAT FROM I = 1 TO SIZE OF SELECTEDANSWER
         IF SELECTEDANSWER[I] EQUAL EXAM.QUESTION[I].CORRECTANSWER THEN
            SET SCORE TO SCORE + EXAM.QUESTION[I].POINT
         END IF
      END REPEAT
      DISPLAY SCORE
   END METHOD


   END_EXAM()
      SET TIMEUP TO TRUE
   END METHOD

END CLASS

