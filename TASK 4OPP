CLASS ATTEMPT

ATTRIBUTES
PRIVATE ID : NUMBER
PRIVATE EXAM : EXAM
PRIVATE SELECTEDANSWER : LIST<TEXT>
PRIVATE SCORE : NUMBER
PRIVATE TIMEUP : BOOLEAN

CONSTRUCTOR(E:EXAM)
    SET EXAM TO E
    SET SELECTEDANSWER TO EMPTY LIST
    SET SCORE TO 0
    SET TIMEUP TO FALSE
END CONSTRUCTOR

METHODS

ADD_ANSWER(A:TEXT)

    IF TIMEUP EQUALS TRUE THEN
        DISPLAY "TIME IS OVER"
    ELSE
        ADD A TO SELECTEDANSWER
    END IF

END METHOD

CALCULATE_SCORE()

    SET SCORE TO 0

    REPEAT FROM I = 1 TO SIZE OF SELECTEDANSWER

        IF SELECTEDANSWER[I] EQUALS EXAM.QUESTION[I].CORRECTANSWER THEN
            SET SCORE TO SCORE + EXAM.QUESTION[I].POINT
        END IF

    END REPEAT

    DISPLAY SCORE

END METHOD

END_EXAM()

    SET TIMEUP TO TRUE

END METHOD

END CLASS


START
BEGIN

CREATE OBJECT EXAM1 OF EXAM("Math Exam",60)

CREATE OBJECT QUESTION1 OF QUESTION("2 + 2 = ?","4",5)

CREATE OBJECT STUDENT1 OF STUDENT("AHMED")

CREATE OBJECT ATTEMPT1 OF ATTEMPT(EXAM1)

EXAM1.ADD_QUESTION(QUESTION1)

ATTEMPT1.ADD_ANSWER("4")

ATTEMPT1.CALCULATE_SCORE()

STUDENT1.ADD_ATTEMPT(ATTEMPT1)

ATTEMPT1.END_EXAM()

END
STOP

